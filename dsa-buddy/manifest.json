{
  "manifest_version": 3,
  "name": "DSA Buddy",
  "version": "1.0.0",
  "description": "Your personal Data Structures and Algorithms mentor — progressive hints, not spoilers.",
  "permissions": ["storage", "sidePanel", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open DSA Buddy"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html"
}
